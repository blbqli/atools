{
  "manifest_version": 3,
  "name": "ATools Sidebar",
  "version": "0.1.0",
  "description": "ATools 纯粹工具站侧边栏入口 + 扩展专属工具（如长截图）。",
  "action": {
    "default_title": "ATools"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "permissions": ["sidePanel", "tabs", "scripting", "activeTab", "downloads"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

